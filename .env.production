# Production environment variables for Kasbnoma
# Copy to .env and modify with actual values before deployment

# Database
DB_USER=kasbnoma
DB_PASSWORD=your-secure-password-here-min-16-chars
DB_NAME=kasbnoma

# Backend/FastAPI
APP_NAME=Kasbnoma API
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend
VITE_API_URL=https://api.yourdomain.com
PORT=3000

# Logging
LOG_LEVEL=info

# Security
PYTHONUNBUFFERED=1
NODE_ENV=production
