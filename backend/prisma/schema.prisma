generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Specialty {
  id           Int       @id @default(autoincrement())
  code         String
  name         String
  university   String
  location     String?
  studyForm    String?   @map("study_form")
  studyType    String?   @map("study_type")
  price        Int       @default(0)
  language     String?
  quota        Int?
  degree       String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([code, university, studyForm], name: "specialty_unique")
  @@index([location])
  @@index([university])
  @@index([language])
  @@index([studyType])
  @@map("specialties")
}